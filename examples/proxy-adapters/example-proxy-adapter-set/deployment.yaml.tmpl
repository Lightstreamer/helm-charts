# Deployment template for the NodeJS remote adapter.
# This file is a template: ${IMAGE_REF} is substituted at deploy time by build.sh
# using envsubst. Do not apply this file directly — use build.sh instead.
apiVersion: apps/v1
kind: Deployment
metadata:
  name: example-proxy-adapter
  namespace: lightstreamer
spec:
  replicas: 1
  selector:
    matchLabels:
      app: example-proxy-adapter
  template:
    metadata:
      labels:
        app: example-proxy-adapter
    spec:
      containers:
        - name: nodejs-adapter
          # Image reference injected by build.sh (format depends on target cluster).
          image: ${IMAGE_REF}
          # IfNotPresent avoids unnecessary pulls and is required for the Minikube
          # docker-env workflow where the image is built directly into the node's daemon.
          imagePullPolicy: IfNotPresent
          args:
            # Hostname of the Lightstreamer Service inside the cluster.
            # Resolves to the headless service created by the Helm chart.
            - lightstreamer-adapters.lightstreamer.svc
            # Port on which the Proxy Data Adapter listens for incoming connections
            # from remote adapters. Must match proxyDataAdapter.requestReplyPort
            # in values.yaml.
            - "6661"
          ports:
            # Informational: the port exposed by the NodeJS adapter process.
            - containerPort: 3000
